params {
//global params

//params.cpus=16
//params.mem=30G
reads=null
csv=null
debug=false
outdir="results"

//we make links for bwa index

//we declare bwa variables
aligner="bwa-mem2"
alt_js="bwa-postalt.js"
alt=true
hla=true
ref="NO_FILE"

//we declare elprep variables
dbsnp="NO_FILE"
dbindel="NO_FILE"
//DV 
autosomes="chr1 chr2 chr3 chr4 chr5 chr6 chr7 chr8 chr9 chr10 chr11 chr12 chr13 chr14 chr15 chr16 chr17 chr18 chr19 chr20 chr21 chr22"
sex="chrX chrY"

}


process {
    withName: 'FASTQC' {
        cpus = 4
	memory = '10 GB'
    }
    withName: 'BWAMEM' {
        cpus = 20
	memory = '60 GB'
    }

  withName: 'MERGEB' {
        cpus = 4
	memory = '10 GB'
    }

    withName: 'QUALIMAP' {
        cpus = 4
	memory = '30 GB'
    }
    withName: 'DEPTH' {
        cpus = 4
       memory = '10 GB'
    }
    withName: 'DEEPVARIANT_AUTOSOMES' {
        cpus = 30
       memory = '40 GB'
    }
    withName: 'GLNEXUS_DEEPVARIANT_AUTOSOMES' {
        cpus = 10
	      memory = '30 GB'
    }

  withName: 'DEEPVARIANT_SEX' {
        cpus = 20
       memory = '40 GB'
    }
    withName: 'GLNEXUS_DEEPVARIANT_SEX' {
        cpus = 10
	      memory = '30 GB'
    }

}
